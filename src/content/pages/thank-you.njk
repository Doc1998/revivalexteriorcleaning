      }

      .Revamp-exterior-cleaning-thank-you {
        font-family: var(--pd-font-body);
        color: #1a1a1a;
        line-height: 1.7;
      }

      /* ── Hero ── */
      .rec-ty-hero {
        position: relative;
        min-height: 480px;
