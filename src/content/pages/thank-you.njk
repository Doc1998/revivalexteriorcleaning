      }

      .rec-ty-service-card__icon {
        width: 46px;
        height: 46px;
        background-color: var(--pd-accent);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 14px;
      }

      .rec-ty-service-card__icon svg {
        color: var(--pd-primary);
      }

      .rec-ty-service-card__title {
        font-family: var(--pd-font-display);
        font-size: 1rem;
        font-weight: 700;
        color: var(--pd-primary);
        margin-bottom: 8px;
