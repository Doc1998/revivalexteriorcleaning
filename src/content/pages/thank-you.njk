        z-index: 2;
        padding: 60px 24px;
        max-width: 700px;
        margin: 0 auto;
      }

      .rec-ty-hero__icon {
        width: 80px;
        height: 80px;
        background-color: var(--pd-accent);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 24px;
      }

      .rec-ty-hero__icon svg {
        color: var(--pd-primary);
      }

      .rec-ty-hero__eyebrow {
        font-family: var(--pd-font-display);
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--pd-accent);
        margin-bottom: 12px;
      }

      .rec-ty-hero h1 {
        font-family: var(--pd-font-display);
        font-size: 2rem;
        font-weight: 800;
        color: var(--pd-white);
        line-height: 1.2;
        margin-bottom: 16px;
      }

      .rec-ty-hero__sub {
        font-size: 1.05rem;
        color: rgba(255,255,255,0.85);
        max-width: 520px;
        margin: 0 auto 32px;
      }

      /* ── CTA Button ── */
      .rec-ty-btn {
        display: inline-block;
        font-family: var(--pd-font-display);
        font-size: 0.9rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        background-color: var(--pd-accent);
        color: var(--pd-primary);
        text-decoration: none;
        padding: 14px 32px;
        border-radius: 4px;
        transition: background 0.2s, transform 0.15s;
      }

      .rec-ty-btn:hover {
        background-color: #d97706;
        transform: translateY(-2px);
      }

      .rec-ty-btn--outline {
        background-color: transparent;
        color: var(--pd-white);
        border: 2px solid var(--pd-white);
        margin-left: 8px;
      }

      .rec-ty-btn--outline:hover {
        background-color: var(--pd-white);
        color: var(--pd-primary);
      }

      /* ── What Happens Next ── */
      .rec-ty-next {
        background-color: var(--pd-white);
        padding: 64px 24px;
      }

      .rec-ty-next__inner {
