      .rec-ty-service-card__link {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-family: var(--pd-font-display);
        font-size: 0.82rem;
        font-weight: 700;
        color: var(--pd-accent);
        margin-top: 12px;
        text-decoration: none;
      }

      /* ── Responsive 768px ── */
      @media (min-width: 768px) {
        .rec-ty-hero h1 {
          font-size: 2.6rem;
        }

        .rec-ty-steps {
          grid-template-columns: 1fr 1fr;
        }

        .rec-ty-service-cards {
          grid-template-columns: repeat(3, 1fr);
        }

        .rec-ty-section-title {
          font-size: 1.9rem;
        }

        .rec-ty-cta-band__title {
          font-size: 2rem;
        }
      }

      /* ── Responsive 1024px ── */
      @media (min-width: 1024px) {
        .rec-ty-hero {
          min-height: 520px;
        }

        .rec-ty-hero h1 {
          font-size: 3rem;
        }

        .rec-ty-steps {
          grid-template-columns: repeat(3, 1fr);
        }
      }
