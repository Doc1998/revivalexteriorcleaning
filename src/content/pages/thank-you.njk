      /* ── CTA Band ── */
      .rec-ty-cta-band {
        background-color: var(--pd-primary);
        padding: 64px 24px;
        text-align: center;
      }

      .rec-ty-cta-band__inner {
        max-width: 700px;
        margin: 0 auto;
      }

      .rec-ty-cta-band__eyebrow {
        font-family: var(--pd-font-display);
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--pd-accent);
        margin-bottom: 12px;
