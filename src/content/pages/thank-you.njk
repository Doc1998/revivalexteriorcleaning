        margin-bottom: 32px;
        max-width: 520px;
        margin-left: auto;
        margin-right: auto;
      }

      .rec-ty-cta-band__buttons {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        justify-content: center;
      }

      /* ── Explore Services ── */
      .rec-ty-explore {
        background-color: var(--pd-white);
        padding: 64px 24px;
      }

      .rec-ty-explore__inner {
        max-width: 960px;
        margin: 0 auto;
        text-align: center;
      }

      .rec-ty-service-cards {
        display: grid;
        grid-template-columns: 1fr;
        gap: 20px;
        margin-top: 40px;
        text-align: left;
      }

      .rec-ty-service-card {
        background-color: var(--pd-light);
        border-radius: 8px;
        padding: 28px 24px;
        box-shadow: 0 2px 12px rgba(15,42,67,0.08);
        text-decoration: none;
        display: block;
        transition: transform 0.18s, box-shadow 0.18s;
      }

