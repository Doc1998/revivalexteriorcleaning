        align-items: flex-start;
        gap: 20px;
        background-color: var(--pd-light);
        border-radius: 8px;
        padding: 24px;
        box-shadow: 0 2px 10px rgba(15,42,67,0.07);
      }

      .rec-ty-step__number {
        flex-shrink: 0;
        width: 48px;
        height: 48px;
        background-color: var(--pd-accent);
        color: var(--pd-primary);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: var(--pd-font-display);
        font-size: 1.1rem;
        font-weight: 800;
      }

      .rec-ty-step__body h3 {
        font-family: var(--pd-font-display);
        font-size: 1rem;
        font-weight: 700;
        color: var(--pd-primary);
        margin-bottom: 6px;
      }

