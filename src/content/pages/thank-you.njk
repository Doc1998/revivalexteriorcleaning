  <style>
      /* ── Page variables ── */
      .Revamp-exterior-cleaning-thank-you {
        --pd-primary: #0F2A43;
        --pd-accent: #F59E0B;
        --pd-light: #E8F4FD;
        --pd-white: #ffffff;
        --pd-font-display: 'Poppins', sans-serif;
